ssh/.ssh/*
!ssh/.ssh/config
.playwright-mcp/

# cmux auto-backup files
cmux/.config/cmux/*.bak

# Codex local state and credentials
# Live config is per-machine (Codex writes state into it); track config.template.toml instead.
codex/.codex/config.toml
codex/.codex/auth.json
codex/.codex/*.sqlite*
codex/.codex/history.jsonl
codex/.codex/session_index.jsonl
codex/.codex/cache/
codex/.codex/log/
codex/.codex/sessions/
codex/.codex/shell_snapshots/
codex/.codex/.tmp/
codex/.codex/tmp/
codex/.codex/models_cache.json
codex/.codex/installation_id
codex/.codex/chrome-native-hosts-v2.json
codex/.codex/.personality_migration
codex/.codex/version.json
codex/.codex/plugins/
codex/.codex/skills/.system/

# Locally copied MCP/env secrets
config/codex/*.env

# gcloud: 크리덴셜은 절대 추적 안 함 (live ~/.config/gcloud 는 비밀+설정 혼재라 stow/추적 안 함).
# gcloud/ 패키지엔 스크립트만 두지만, 실수 대비 가드:
gcloud/**/ga-sa-key.json
gcloud/**/*credentials*
gcloud/**/*.db
gcloud/**/legacy_credentials/
gcloud/.config/gcloud/
