[
  {
    "context": "VimControl && !menu",
    "bindings": {
      // Put key bindings here if you want them to work in normal & visual mode.
      "g r": "editor::FindAllReferences",
      "space d": "editor::GoToDiagnostic",
      "space D": "diagnostics::Deploy",
      "space c": "vim::ToggleComments",
      "space f": "file_finder::Toggle",
      "space t": "tab_switcher::Toggle",
      "space e": "workspace::ToggleLeftDock",
      "space o": "outline::Toggle",
      // split
      "space s d": "editor::GoToDefinitionSplit",
      "space s v": "pane::SplitVertical",
      "space s h": "pane::SplitHorizontal",
      // window
      "space w h": "workspace::ActivatePaneLeft",
      "space w j": "workspace::ActivatePaneDown",
      "space w k": "workspace::ActivatePaneUp",
      "space w l": "workspace::ActivatePaneRight",
      // tasks
      "space g g": [
        "task::Spawn",
        { "task_name": "start_lazygit", "reveal_target": "center" },
      ],
    },
  },
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      // "shift-y": ["workspace::SendKeystrokes", "y $"] // Use neovim's yank behavior: yank to end of line.
    },
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore", // In insert mode, make jk escape to normal mode.
    },
  },
  {
    "context": "vim_mode == visual",
    "bindings": {
      "shift-j": "editor::MoveLineDown",
      "shift-k": "editor::MoveLineUp",
    },
  },
  {
    "context": "EmptyPane || SharedScreen",
    "bindings": {
      // Put key bindings here (in addition to the context above) if you want them to
      // work when no editor exists.
      // "space f": "file_finder::Toggle"
    },
  },
  {
    "context": "vim_operator == a || vim_operator == i || vim_operator == cs",
    "bindings": {
      // Traditional Vim behavior
      "q": "vim::AnyQuotes",
      "b": "vim::AnyBrackets",

      // mini.ai plugin behavior
      "Q": "vim::MiniQuotes",
      "B": "vim::MiniBrackets",
    },
  },
]
